GOOGLE_API_KEY=your_api_key_here

# API (apps/api)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://trydocumind.vercel.app
SESSION_TTL_MINUTES=30
RATE_LIMIT_PER_HOUR=20
MAX_PDF_SIZE_MB=10

# S3-compatible object storage (Backblaze B2) — optional; omit for in-memory only
# S3_ENDPOINT_URL=https://s3.<region>.backblazeb2.com
# S3_REGION=<region>
# S3_ACCESS_KEY_ID=<keyID>
# S3_SECRET_ACCESS_KEY=<applicationKey>
# S3_BUCKET_NAME=<bucket-name>

# Auth v3 — Neon Postgres
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Auth v3 — Clerk
# Web (Vercel + apps/web/.env.local) needs BOTH keys. Missing CLERK_SECRET_KEY
# NEXT_PUBLIC_CLERK_SECRET_KEYE_INVOCATION_FAILED (site 500) on Vercel.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# API (Render) verifies JWTs:
# CLERK_JWKS_URL=https://<your-frontend-api>/.well-known/jwks.json
# CLERK_ISSUER=  # optional
# INVITE_EXPIRY_DAYS=7
